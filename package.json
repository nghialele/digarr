{
  "name": "digarr",
  "version": "1.0.0-rc.5",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:web": "vite",
    "build": "vite build && bun build src/index.ts --outdir dist/server --target bun",
    "start": "bun dist/server/index.js",
    "i18n:check": "bun scripts/i18n-check.ts",
    "check:api-docs": "bun scripts/check-api-docs.ts",
    "i18n:translate": "bun scripts/i18n-machine-translate.ts",
    "test": "vitest run",
    "test:api-routes": "vitest run tests/api-routes/",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:a11y": "playwright test --config=playwright.a11y.config.ts"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "esbuild": "^0.28.0",
    "picomatch": "^4.0.4",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "openai": "^6.39.1",
    "openid-client": "^6.8.4",
    "p-queue": "^9.3.0",
    "p-retry": "^8.0.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  }
}
