{
  "name": "digarr",
  "version": "0.12.11",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:web": "vite",
    "build": "vite build && bun build src/index.ts --outdir dist/server --target bun",
    "start": "bun dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "esbuild": "0.27.4",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^1.7.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@hono/node-server": "^1.19.11",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "openai": "^6.31.0",
    "openid-client": "^6.8.2",
    "p-queue": "^9.1.0",
    "pg": "^8.20.0"
  }
}
