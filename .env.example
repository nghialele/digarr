# =============================================================================
# Database
# =============================================================================
# Full connection string (takes precedence over individual DB_* vars)
DATABASE_URL=postgresql://digarr:digarr@localhost:5432/digarr

# Or set individual vars (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=digarr
# DB_PASS=digarr
# DB_NAME=digarr

# =============================================================================
# Server
# =============================================================================
PORT=3000

# CORS: set to your app's URL if accessed from a different origin.
# In production (NODE_ENV=production), defaults to same-origin only.
# ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# Lidarr
# =============================================================================
# LIDARR_URL=http://localhost:8686
# LIDARR_API_KEY=your-lidarr-api-key
# SKIP_TLS_VERIFY=false

# =============================================================================
# Listening sources (at least one required)
# =============================================================================
# LISTENBRAINZ_USERNAME=your-username
# LISTENBRAINZ_TOKEN=your-listenbrainz-token

# LASTFM_USERNAME=your-username
# LASTFM_API_KEY=your-lastfm-api-key

# =============================================================================
# AI provider
# =============================================================================
# AI_PROVIDER=openai        # openai, anthropic, or ollama
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=your-ai-api-key
# AI_BASE_URL=              # optional, for ollama or compatible APIs
