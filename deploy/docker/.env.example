# Digarr Docker Compose Configuration
#
# Copy to .env and fill in your values.
# All service vars are optional here -- you can configure them via the web UI
# instead. If all required vars are set, setup completes automatically on boot.

# =============================================================================
# Database (used by both postgres container and app)
# =============================================================================
DB_USER=digarr
DB_PASS=digarr
DB_NAME=digarr

# =============================================================================
# Server
# =============================================================================
PORT=3000
# ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# Lidarr
# =============================================================================
# LIDARR_URL=http://lidarr:8686
# LIDARR_API_KEY=
# SKIP_TLS_VERIFY=false

# =============================================================================
# Listening sources (at least one required for auto-setup)
# =============================================================================
# LISTENBRAINZ_USERNAME=
# LISTENBRAINZ_TOKEN=

# LASTFM_USERNAME=
# LASTFM_API_KEY=

# =============================================================================
# AI provider
# =============================================================================
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=
# AI_BASE_URL=
